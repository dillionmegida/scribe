{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/main",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src/main/**/*", "src/renderer/**/*"]
}