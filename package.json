{
  "name": "whisper-scribe",
  "version": "1.0.0",
  "description": "Video transcription app using Whisper",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "NODE_ENV=production webpack --config webpack.config.js",
    "build:icon": "node scripts/generate-icon.js",
    "start": "npm run build && electron .",
    "dev": "npm run build:main && concurrently --kill-others \"tsc -p tsconfig.json --watch\" \"webpack serve --config webpack.config.js\" \"wait-on http://localhost:3000 && NODE_ENV=development electronmon .\"",
    "build": "npm run build:main && npm run build:renderer && electron-builder"
  },
  "build": {
    "appId": "com.scribe.app",
    "productName": "Scribe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage"
    }
  },
  "electronmon": {
    "patterns": [
      "!src/**",
      "!dist/renderer/**"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^10.0.0",
    "babel-loader": "^10.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.15.3",
    "electronmon": "^2.0.4",
    "html-webpack-plugin": "^5.6.6",
    "sharp": "^0.35.2",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4",
    "webpack": "^5.106.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "styled-components": "^6.3.12",
    "uuid": "^9.0.1"
  }
}
